/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": ".",
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "paths": {
      "@ngx-better-forms/better-forms": [
        "./dist/@ngx-better-forms/better-forms"
      ],
      "@ngx-better-forms/core": [
        "./dist/@ngx-better-forms/core"
      ],
      "@ngx-better-forms/reactive": [
        "./dist/@ngx-better-forms/reactive"
      ],
      "@ngx-better-forms/signals": [
        "./dist/@ngx-better-forms/signals"
      ]
    },
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve"
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "typeCheckHostBindings": true,
    "strictTemplates": true
  },
  "include": [
    "./dist/**/*"
  ],
  "files": [],
  "references": [
    {
      "path": "./projects/ngx-better-forms/tsconfig.lib.json"
    },
    {
      "path": "./projects/ngx-better-forms/tsconfig.spec.json"
    },
    {
      "path": "./projects/ngx-better-forms-docs/tsconfig.app.json"
    },
    {
      "path": "./projects/ngx-better-forms-docs/tsconfig.spec.json"
    },
    {
      "path": "./projects/ngx-better-forms-reactive/tsconfig.lib.json"
    },
    {
      "path": "./projects/ngx-better-forms-reactive/tsconfig.spec.json"
    },
    {
      "path": "./projects/ngx-better-forms-signals/tsconfig.lib.json"
    },
    {
      "path": "./projects/ngx-better-forms-signals/tsconfig.spec.json"
    },
    {
      "path": "./projects/ngx-better-forms-core/tsconfig.lib.json"
    },
    {
      "path": "./projects/ngx-better-forms-core/tsconfig.spec.json"
    }
  ]
}
