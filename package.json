{
  "name": "ngx-better-forms-workspace",
  "type": "module",
  "scripts": {
    "start": "ng serve ngx-better-forms-docs",

    "build:lib": "ng build ngx-better-forms-core && ng build ngx-better-forms-reactive && ng build ngx-better-forms-signals && ng build ngx-better-forms",
    "build:docs": "npm run script:extract-code-examples && ng build ngx-better-forms-docs --base-href /ngx-better-forms/ --configuration production",

    "build:core:watch": "ng build ngx-better-forms-core --watch --configuration development",
    "build:reactive:watch": "ng build ngx-better-forms-reactive --watch --configuration development",
    "build:signals:watch": "ng build ngx-better-forms-signals --watch --configuration development",
    "build:all:watch": "ng build ngx-better-forms --watch --configuration development",

    "build:core": "ng build ngx-better-forms-core --configuration production",
    "build:reactive": "ng build ngx-better-forms-reactive --configuration production",
    "build:signals": "ng build ngx-better-forms-signals --configuration production",
    "build:all": "npm run build:core && npm run build:reactive && npm run build:signals && ng build ngx-better-forms --configuration production",

    "test:reactive": "ng test ngx-better-forms-reactive",
    "test:signals": "ng test ngx-better-forms-signals",

    "test:reactive:ci": "ng test ngx-better-forms-reactive --watch=false --browsers=ChromeHeadless --no-progress",
    "test:signals:ci": "ng test ngx-better-forms-signals --watch=false --browsers=ChromeHeadless --no-progress",

    "script:extract-code-examples": "tsx projects/ngx-better-forms-docs/scripts/extract-code-examples.ts",
    "script:copy-readme": "tsx scripts/copy.ts README.md projects/ngx-better-forms/README.md"
  },
  "prettier": {
    "printWidth": 120,
    "singleQuote": true,
    "trailingComma": "all",
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.0.0-next.0",
    "@angular/compiler": "^21.0.0-next.0",
    "@angular/core": "^21.0.0-next.0",
    "@angular/forms": "^21.0.0-next.0",
    "@angular/platform-browser": "^21.0.0-next.0",
    "@angular/router": "^21.0.0-next.0",
    "prism-material-themes": "^1.0.5",
    "prismjs": "^1.30.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.0-next.0",
    "@angular/cli": "^21.0.0-next.0",
    "@angular/compiler-cli": "^21.0.0-next.0",
    "@tailwindcss/postcss": "4.1.4",
    "@types/jasmine": "~5.1.0",
    "@types/js-beautify": "^1.14.3",
    "@types/prismjs": "^1.26.5",
    "daisyui": "^5.4.7",
    "jasmine-core": "~5.9.0",
    "js-beautify": "^1.15.4",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^21.0.0-next.0",
    "postcss": "8.5.3",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.20.6",
    "typescript": "~5.9.2"
  }
}
